<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Tour Virtual 360°</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/pannellum/build/pannellum.css">
  <script src="https://cdn.jsdelivr.net/npm/pannellum/build/pannellum.js"></script>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family: sans-serif; background: #111; display:flex; }
    #nav { width:220px; min-height:100vh; background:rgba(0,0,0,0.8);
           overflow-y:auto; padding:12px 0; flex-shrink:0; }
    #nav h2 { color:#aaa; font-size:11px; padding:8px 14px;
              text-transform:uppercase; letter-spacing:.05em; }
    .item { padding:9px 14px; color:rgba(255,255,255,.7); cursor:pointer;
            font-size:13px; border-left:2px solid transparent; }
    .item:hover, .item.active { background:rgba(255,255,255,.08);
                                color:white; border-left-color:#4a9eff; }
    #panorama { flex:1; height:100vh; }
  </style>
</head>
<body>
<div id="nav"><h2>Escenas</h2></div>
<div id="panorama"></div>
<script>
fetch('scenes.json').then(r=>r.json()).then(data=>{
  const nav = document.getElementById('nav');
  const ids = Object.keys(data.scenes);
  let viewer;
  ids.forEach(id=>{
    const el = document.createElement('div');
    el.className = 'item' + (id===ids[0]?' active':'');
    el.textContent = data.scenes[id].title;
    el.onclick = ()=>{
      viewer.loadScene(id);
      document.querySelectorAll('.item').forEach(e=>e.classList.remove('active'));
      el.classList.add('active');
    };
    nav.appendChild(el);
  });
  viewer = pannellum.viewer('panorama',{
    default:{firstScene:ids[0],sceneFadeDuration:800},
    scenes:data.scenes
  });
});
</script>
</body>
</html>
